/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default parameter values
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // Input/output options

    // Reference data options
    organism = null
    organ = "brain"
    census_version = null
    ref_keys = ["subclass", "class", "family", "global"]
    ref_collections = null
    ref_split = "dataset_title"
    subsample_ref = 500
    relabel_r = null

    // Query data options
    queries_adata = null
    relabel_q = null
    subsample_query = 100
    remove_unknown = true

    // Batch correction
    batch_correct = true
    batch_keys = [
        "lau": "sample",
        "pineda": "Batch",
        "lim": "batch",
        "velmeshev": "sample",
        "rosmap": "batch",
        "nagy": "batch"
    ]

    // Model parameters
    cutoff = 0
    use_gap = false
    seed = 42
    nmads = 5
    knn_n_neighbors = 15

    // Seurat parameters
    normalization_method = "SCT"
    nfeatures = 2000
    integration_method = "pcaproject"
    dims = 50
    max_features = 200
    k_anchor = 10
    k_score = 30
    k_weight = 50

    // Subset options
    subset_type = "sample"

    // Author cell type annotation files (optional; used to map original author labels)
    author_annotations_path = null
    original_celltype_columns = null

    // Resource files
    markers_file = "$projectDir/assets/cell_type_markers.tsv"
    gene_mapping = "$projectDir/assets/gemma_genes.tsv"
    multiqc_config = "$projectDir/assets/multiqc_config.yaml"

    outdir_prefix = "${params.census_version}/${params.organism}/${params.subsample_query}/${params.ref_split}/${params.normalization_method}/gap_${params.use_gap}"
    outdir = "$projectDir/${params.outdir_prefix}/ref_${params.subsample_ref}/cutoff_${params.cutoff}"


}
